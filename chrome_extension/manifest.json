{
  "manifest_version": 3,
  "name": "Fraud Detection Assessor",
  "version": "1.0",
  "description": "Evaluates transaction fraud risk using an advanced XGBoost ML backend.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check Fraud Risk"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}
